{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_GOOGLE_GENERATIVE_AI_KEY": "@vite_google_generative_ai_key",
    "VITE_GOOGLE_CLIENT_ID": "@vite_google_client_id"
  }
}
